{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truecaddie.local/schemas/course-bundle.v1.schema.json",
  "title": "TrueCaddie Course Bundle V1",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_version",
    "course_id",
    "course_name",
    "published_at",
    "provenance",
    "holes"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "bundle_version": {
      "type": "string",
      "minLength": 1
    },
    "course_id": {
      "type": "string",
      "minLength": 1
    },
    "course_name": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "holes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/hole"
      }
    }
  },
  "$defs": {
    "position": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "number"
      }
    },
    "geometry": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "coordinates": {}
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_system",
        "derivation_version"
      ],
      "properties": {
        "source_system": {
          "type": "string"
        },
        "source_path": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "source_updated_at": {
          "type": "string"
        },
        "derivation_version": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "hole": {
      "type": "object",
      "required": [
        "hole_id",
        "hole_number",
        "par",
        "tees",
        "base_mapping_data",
        "strategy_overlays",
        "quality_confidence",
        "provenance"
      ],
      "properties": {
        "hole_id": {
          "type": "string"
        },
        "hole_number": {
          "type": "integer"
        },
        "par": {
          "type": "integer"
        },
        "default_play_direction": {
          "type": "object",
          "additionalProperties": true
        },
        "tees": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tee"
          }
        },
        "base_mapping_data": {
          "$ref": "#/$defs/baseMappingData"
        },
        "strategy_overlays": {
          "$ref": "#/$defs/strategyOverlays"
        },
        "quality_confidence": {
          "$ref": "#/$defs/qualityConfidence"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      },
      "additionalProperties": true
    },
    "tee": {
      "type": "object",
      "required": [
        "tee_set_id",
        "name",
        "tee_coordinate",
        "tee_length_m"
      ],
      "properties": {
        "tee_set_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "tee_coordinate": {
          "$ref": "#/$defs/position"
        },
        "tee_length_m": {
          "type": "number"
        },
        "is_default": {
          "type": "boolean"
        }
      }
    },
    "baseMappingData": {
      "type": "object",
      "required": [
        "centerline",
        "green",
        "features",
        "out_of_bounds_lines",
        "context_points"
      ],
      "properties": {
        "centerline": {
          "$ref": "#/$defs/geometry"
        },
        "green": {
          "type": "object",
          "additionalProperties": true
        },
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "feature_id",
              "feature_type",
              "geometry",
              "properties"
            ],
            "properties": {
              "feature_id": {
                "type": "string"
              },
              "feature_type": {
                "type": "string"
              },
              "hazard_kind": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "geometry": {
                "$ref": "#/$defs/geometry"
              },
              "properties": {
                "type": "object",
                "additionalProperties": true
              }
            }
          }
        },
        "out_of_bounds_lines": {
          "type": "array"
        },
        "context_points": {
          "type": "array"
        }
      }
    },
    "strategyOverlays": {
      "type": "object",
      "required": [
        "tee_target_corridors",
        "aggressive_tee_corridors",
        "layup_candidates",
        "preferred_miss",
        "hazard_severity"
      ],
      "properties": {
        "tee_target_corridors": {
          "type": "array"
        },
        "aggressive_tee_corridors": {
          "type": "array"
        },
        "layup_candidates": {
          "type": "array"
        },
        "preferred_miss": {
          "type": "array"
        },
        "hazard_severity": {
          "type": "array"
        }
      }
    },
    "qualityConfidence": {
      "type": "object",
      "required": [
        "hole_publish_confidence",
        "hole_publish_score",
        "notes"
      ],
      "properties": {
        "hole_publish_confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "hole_publish_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "overlay_scores": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
