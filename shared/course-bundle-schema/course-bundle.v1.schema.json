{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://truecaddie.local/schemas/course-bundle.v1.schema.json",
  "title": "TrueCaddie Course Bundle V1",
  "type": "object",
  "required": [
    "schema_version",
    "bundle_version",
    "course_id",
    "course_name",
    "published_at",
    "provenance",
    "holes"
  ],
  "properties": {
    "schema_version": {
      "const": "v1"
    },
    "bundle_version": {
      "type": "string",
      "minLength": 1
    },
    "course_id": {
      "type": "string",
      "minLength": 1
    },
    "course_name": {
      "type": "string",
      "minLength": 1
    },
    "published_at": {
      "type": "string",
      "format": "date-time"
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "holes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/hole"
      }
    }
  },
  "$defs": {
    "position": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "number"
      }
    },
    "geometry": {
      "type": "object",
      "required": [
        "type",
        "coordinates"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "coordinates": {}
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_system",
        "derivation_version"
      ],
      "properties": {
        "source_system": {
          "type": "string"
        },
        "source_path": {
          "type": "string"
        },
        "source_file": {
          "type": "string"
        },
        "source_updated_at": {
          "type": "string"
        },
        "derivation_version": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "hole": {
      "type": "object",
      "required": [
        "hole_id",
        "hole_number",
        "par",
        "tees",
        "base_mapping_data",
        "strategy_overlays",
        "quality_confidence",
        "provenance"
      ],
      "properties": {
        "hole_id": {
          "type": "string"
        },
        "hole_number": {
          "type": "integer"
        },
        "par": {
          "type": "integer"
        },
        "default_play_direction": {
          "$ref": "#/$defs/defaultPlayDirection"
        },
        "tees": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/tee"
          }
        },
        "base_mapping_data": {
          "$ref": "#/$defs/baseMappingData"
        },
        "strategy_overlays": {
          "$ref": "#/$defs/strategyOverlays"
        },
        "quality_confidence": {
          "$ref": "#/$defs/qualityConfidence"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      },
      "additionalProperties": false
    },
    "defaultPlayDirection": {
      "type": "object",
      "required": [
        "bearingDeg"
      ],
      "properties": {
        "bearingDeg": {
          "type": "number"
        }
      },
      "additionalProperties": true
    },
    "tee": {
      "type": "object",
      "required": [
        "tee_set_id",
        "name",
        "tee_coordinate",
        "tee_length_m"
      ],
      "properties": {
        "tee_set_id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "tee_coordinate": {
          "$ref": "#/$defs/position"
        },
        "tee_length_m": {
          "type": "number"
        },
        "is_default": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "baseMappingData": {
      "type": "object",
      "required": [
        "centerline",
        "green",
        "features",
        "out_of_bounds_lines",
        "context_points"
      ],
      "properties": {
        "centerline": {
          "$ref": "#/$defs/geometry"
        },
        "green": {
          "$ref": "#/$defs/greenReference"
        },
        "features": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "feature_id",
              "feature_type",
              "geometry",
              "properties"
            ],
            "properties": {
              "feature_id": {
                "type": "string"
              },
              "feature_type": {
                "type": "string"
              },
              "hazard_kind": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "geometry": {
                "$ref": "#/$defs/geometry"
              },
              "properties": {
                "type": "object",
                "additionalProperties": true
              }
            },
            "additionalProperties": false
          }
        },
        "out_of_bounds_lines": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/geoJsonFeature"
          }
        },
        "context_points": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/geoJsonFeature"
          }
        }
      },
      "additionalProperties": false
    },
    "greenReference": {
      "type": "object",
      "required": [
        "center",
        "front_center",
        "back_center",
        "center_elevation_m",
        "front_elevation_m",
        "back_elevation_m",
        "polygon_feature_id"
      ],
      "properties": {
        "center": {
          "$ref": "#/$defs/position"
        },
        "front_center": {
          "anyOf": [
            {
              "$ref": "#/$defs/position"
            },
            {
              "type": "null"
            }
          ]
        },
        "back_center": {
          "anyOf": [
            {
              "$ref": "#/$defs/position"
            },
            {
              "type": "null"
            }
          ]
        },
        "center_elevation_m": {
          "type": [
            "number",
            "null"
          ]
        },
        "front_elevation_m": {
          "type": [
            "number",
            "null"
          ]
        },
        "back_elevation_m": {
          "type": [
            "number",
            "null"
          ]
        },
        "polygon_feature_id": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "geoJsonFeature": {
      "type": "object",
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "id": {
          "type": [
            "string",
            "null"
          ]
        },
        "geometry": {
          "anyOf": [
            {
              "$ref": "#/$defs/geometry"
            },
            {
              "type": "null"
            }
          ]
        },
        "properties": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    },
    "strategyOverlays": {
      "type": "object",
      "required": [
        "tee_target_corridors",
        "aggressive_tee_corridors",
        "layup_candidates",
        "preferred_miss",
        "hazard_severity"
      ],
      "properties": {
        "tee_target_corridors": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/teeTargetCorridorOverlay"
          }
        },
        "aggressive_tee_corridors": {
          "type": "array"
        },
        "layup_candidates": {
          "type": "array"
        },
        "preferred_miss": {
          "type": "array"
        },
        "hazard_severity": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/hazardSeverityOverlay"
          }
        }
      },
      "additionalProperties": false
    },
    "hazardSeverityOverlay": {
      "type": "object",
      "required": [
        "overlay_id",
        "overlay_type",
        "course_id",
        "hole_id",
        "tee_set_id",
        "shot_phase",
        "geometry",
        "properties",
        "confidence",
        "rationale",
        "constraints",
        "provenance"
      ],
      "properties": {
        "overlay_id": {
          "type": "string",
          "minLength": 1
        },
        "overlay_type": {
          "const": "hazard_severity"
        },
        "course_id": {
          "type": "string",
          "minLength": 1
        },
        "hole_id": {
          "type": "string",
          "minLength": 1
        },
        "tee_set_id": {
          "type": "string",
          "minLength": 1
        },
        "shot_phase": {
          "type": "string",
          "minLength": 1
        },
        "geometry": {
          "$ref": "#/$defs/geometry"
        },
        "properties": {
          "$ref": "#/$defs/hazardSeverityProperties"
        },
        "confidence": {
          "$ref": "#/$defs/overlayConfidence"
        },
        "rationale": {
          "$ref": "#/$defs/overlayRationale"
        },
        "constraints": {
          "$ref": "#/$defs/overlayConstraints"
        },
        "provenance": {
          "$ref": "#/$defs/overlayProvenance"
        }
      },
      "additionalProperties": false
    },
    "teeTargetCorridorOverlay": {
      "type": "object",
      "required": [
        "overlay_id",
        "overlay_type",
        "course_id",
        "hole_id",
        "tee_set_id",
        "shot_phase",
        "geometry",
        "properties",
        "confidence",
        "rationale",
        "constraints",
        "provenance"
      ],
      "properties": {
        "overlay_id": {
          "type": "string",
          "minLength": 1
        },
        "overlay_type": {
          "const": "tee_target_corridor"
        },
        "course_id": {
          "type": "string",
          "minLength": 1
        },
        "hole_id": {
          "type": "string",
          "minLength": 1
        },
        "tee_set_id": {
          "type": "string",
          "minLength": 1
        },
        "shot_phase": {
          "const": "tee"
        },
        "geometry": {
          "$ref": "#/$defs/geometry"
        },
        "properties": {
          "$ref": "#/$defs/teeTargetCorridorProperties"
        },
        "confidence": {
          "$ref": "#/$defs/overlayConfidence"
        },
        "rationale": {
          "$ref": "#/$defs/overlayRationale"
        },
        "constraints": {
          "$ref": "#/$defs/overlayConstraints"
        },
        "provenance": {
          "$ref": "#/$defs/overlayProvenance"
        }
      },
      "additionalProperties": false
    },
    "teeTargetCorridorProperties": {
      "type": "object",
      "required": [
        "target_distance_m",
        "corridor_width_m",
        "corridor_depth_m",
        "target_label",
        "fairway_feature_id",
        "strategy_mode"
      ],
      "properties": {
        "target_distance_m": {
          "type": "number",
          "minimum": 0
        },
        "corridor_width_m": {
          "type": "number",
          "minimum": 1
        },
        "corridor_depth_m": {
          "type": "number",
          "minimum": 1
        },
        "target_label": {
          "type": "string",
          "minLength": 1
        },
        "fairway_feature_id": {
          "type": "string",
          "minLength": 1
        },
        "strategy_mode": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "hazardSeverityProperties": {
      "type": "object",
      "required": [
        "hazard_ref_id",
        "hazard_kind",
        "severity_band",
        "severity_score",
        "context_relevance_score",
        "penalty_kind",
        "landing_conflict",
        "blocks_recovery"
      ],
      "properties": {
        "hazard_ref_id": {
          "type": "string",
          "minLength": 1
        },
        "hazard_kind": {
          "type": "string",
          "minLength": 1
        },
        "severity_band": {
          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ]
        },
        "severity_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "context_relevance_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "penalty_kind": {
          "type": "string",
          "minLength": 1
        },
        "landing_conflict": {
          "type": "boolean"
        },
        "blocks_recovery": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "overlayConfidence": {
      "type": "object",
      "required": [
        "band",
        "score"
      ],
      "properties": {
        "band": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "overlayRationale": {
      "type": "object",
      "required": [
        "primary_reason"
      ],
      "properties": {
        "primary_reason": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "overlayConstraints": {
      "type": "object",
      "required": [
        "derived_from"
      ],
      "properties": {
        "derived_from": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "overlayProvenance": {
      "type": "object",
      "required": [
        "derivation_version"
      ],
      "properties": {
        "source_file": {
          "type": [
            "string",
            "null"
          ]
        },
        "derivation_version": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "qualityConfidence": {
      "type": "object",
      "required": [
        "hole_publish_confidence",
        "hole_publish_score",
        "notes"
      ],
      "properties": {
        "hole_publish_confidence": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "hole_publish_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "overlay_scores": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  }
}
